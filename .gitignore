########################################
.idea/
*.iml
*.iws
*.ipr
out/

########################################
# VS Code (defensive)
########################################
.vscode/

########################################
# OS / Environment
########################################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

########################################
