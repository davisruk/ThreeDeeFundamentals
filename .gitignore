# Gradle
########################################
.gradle/
build/

# Gradle cache (if using Kotlin DSL)
**/build/

# Gradle wrapper (KEEP these)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

########################################
# Eclipse
########################################
.project
.classpath
.settings/
.metadata/

# Eclipse launch configs
*.launch

########################################
